{
  "entities": {
    "clinics": {
      "title": "Clinics",
      "description": "Dental clinics registered in the system",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "cnpj": { "type": "string" },
        "cro": { "type": "string" },
        "address": { "type": "string" },
        "cep": { "type": "string" },
        "district": { "type": "string" },
        "city": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId"]
    },
    "dentists": {
      "title": "Dentists",
      "description": "Dentists working at clinics",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "cpf": { "type": "string" },
        "cro": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "cep": { "type": "string" },
        "district": { "type": "string" },
        "city": { "type": "string" },
        "specialty": { "type": "string" },
        "clinicId": { "type": "string" },
        "googleCalendarId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "clinicId"]
    },
    "patients": {
      "title": "Patients",
      "description": "Patients in the CRM / Funnel",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "clinicId": { "type": "string" },
        "status": { 
          "type": "string",
          "enum": ["lead", "scheduled", "completed", "lost"]
        },
        "lastContactAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "clinicId", "phone"]
    },
    "appointments": {
      "title": "Appointments",
      "description": "Scheduled dental appointments",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "dentistId": { "type": "string" },
        "clinicId": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"] },
        "googleEventId": { "type": "string" }
      },
      "required": ["patientId", "dentistId", "startTime", "endTime"]
    },
    "procedures": {
      "title": "Procedures",
      "description": "Procedures performed in the clinic or by dentists",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "value": { "type": "number" },
        "dentistId": { "type": "string" },
        "clinicId": { "type": "string" },
        "registrationDate": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["type", "value", "dentistId", "clinicId", "registrationDate", "ownerId"]
    },
    "specialties": {
      "title": "Specialties",
      "description": "Customizable dental specialties",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "iconColor": { "type": "string" },
        "bgColor": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId"]
    },
    "users": {
      "title": "Users",
      "description": "Dentists/Users registered in the administrative panel",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "email": { "type": "string" },
        "cpf": { "type": "string" },
        "whatsapp": { "type": "string" },
        "dataNascimento": { "type": "string" },
        "endereco": { "type": "string" },
        "bairro": { "type": "string" },
        "cidade": { "type": "string" },
        "estado": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nome", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User core profile settings and PII"
    },
    "/clinics/{clinicId}": {
      "schema": "clinics",
      "description": "Main clinic documents"
    },
    "/dentists/{dentistId}": {
      "schema": "dentists",
      "description": "Root dentists collection"
    },
    "/pacientes/{pacienteId}": {
      "schema": "patients",
      "description": "Root pacientes collection"
    },
    "/appointments/{appointmentId}": {
      "schema": "appointments",
      "description": "Root appointments collection"
    },
    "/procedures/{procedureId}": {
      "schema": "procedures",
      "description": "Root procedures collection"
    },
    "/specialties/{specialtyId}": {
      "schema": "specialties",
      "description": "Custom dental specialties collection"
    }
  }
}
